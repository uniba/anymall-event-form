generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SlotState {
  APPLICATIONS_CLOSED
  ACCEPTING_APPLICATIONS
}

enum SlotApplicationStatus {
  APPLIED
  WAITLISTED
  ACCEPTED
  REJECTED
  CANCELED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum Prefecture {
  北海道
  青森県
  岩手県
  宮城県
  秋田県
  山形県
  福島県
  茨城県
  栃木県
  群馬県
  埼玉県
  千葉県
  東京都
  神奈川県
  新潟県
  富山県
  石川県
  福井県
  山梨県
  長野県
  岐阜県
  静岡県
  愛知県
  三重県
  滋賀県
  京都府
  大阪府
  兵庫県
  奈良県
  和歌山県
  鳥取県
  島根県
  岡山県
  広島県
  山口県
  徳島県
  香川県
  愛媛県
  高知県
  福岡県
  佐賀県
  長崎県
  熊本県
  大分県
  宮崎県
  鹿児島県
  沖縄県
  海外
}

model Submission {
  id                String           @id @default(cuid())
  name              String
  furigana          String
  email             String           @unique
  gender            Gender?
  birthday          DateTime?
  prefecture        Prefecture?
  memo              String?
  slotApplications  SubmissionSlot[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  address   String
  slots     Slot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slot {
  id                  String           @id @default(cuid())
  venueId             String
  venue               Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  eventName           String           @default("未設定イベント")
  theme               String           @default("Not decided")
  instructor          String           @default("Not decided")
  capacity            Int              @default(0)
  applicationBegin    DateTime
  applicationDeadline DateTime
  lotteryResultTime   DateTime
  startsAt            DateTime
  endsAt              DateTime
  state               SlotState        @default(ACCEPTING_APPLICATIONS)
  applications        SubmissionSlot[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([venueId, startsAt])
  @@index([state])
  @@index([state, applicationBegin, applicationDeadline])
}

model SubmissionSlot {
  id                  String                @id @default(cuid())
  submissionId        String
  slotId              String
  submissionAttemptId String
  receiptEmailSentAt  DateTime?
  submission          Submission            @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  slot                Slot                  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  appliedAt           DateTime              @default(now())
  status              SlotApplicationStatus @default(APPLIED)
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([submissionId, slotId, submissionAttemptId])
  @@index([slotId, status])
  @@index([submissionId])
  @@index([submissionId, submissionAttemptId])
}
