generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SlotState {
  APPLICATIONS_CLOSED
  ACCEPTING_APPLICATIONS
}

enum SlotApplicationStatus {
  APPLIED
  WAITLISTED
  ACCEPTED
  REJECTED
  CANCELED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

model Submission {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  gender            Gender
  birthday          DateTime
  slotApplications  SubmissionSlot[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  address   String?
  slots     Slot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slot {
  id                  String           @id @default(cuid())
  venueId             String
  venue               Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  eventName           String           @default("未設定イベント")
  theme               String           @default("Not decided")
  instructor          String           @default("Not decided")
  capacity            Int              @default(0)
  applicationBegin    DateTime
  applicationDeadline DateTime
  lotteryResultTime   DateTime
  startsAt            DateTime
  endsAt              DateTime
  state               SlotState        @default(ACCEPTING_APPLICATIONS)
  applications        SubmissionSlot[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([venueId, startsAt])
  @@index([state])
  @@index([state, applicationBegin, applicationDeadline])
}

model SubmissionSlot {
  id                  String                @id @default(cuid())
  submissionId        String
  slotId              String
  submissionAttemptId String
  receiptEmailSentAt  DateTime?
  submission          Submission            @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  slot                Slot                  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  appliedAt           DateTime              @default(now())
  status              SlotApplicationStatus @default(APPLIED)
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([submissionId, slotId, submissionAttemptId])
  @@index([slotId, status])
  @@index([submissionId])
  @@index([submissionId, submissionAttemptId])
}
